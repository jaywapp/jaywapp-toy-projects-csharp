<Window x:Class="WeddingVisitor.Dialog.SelectHostDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WeddingVisitor.Dialog"
        mc:Ignorable="d"
        Title="신랑/신부 선택" Height="300" Width="600">
    <Window.Resources>
        <Style TargetType="TextBlock" x:Key="DescStyle">
            <Setter Property="FontSize" Value="20"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="TextAlignment" Value="Center"/>
        </Style>

        <Style TargetType="Button" x:Key="ButtonBaseStyle">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Margin"  Value="5"/>
            <Setter Property="BorderThickness" Value="3"/>
            <Setter Property="ContentTemplate">
                <Setter.Value>
                    <DataTemplate>
                        <TextBlock Text="{Binding}" FontSize="40" />
                    </DataTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="Button" x:Key="GroomButtonStyle" BasedOn="{StaticResource ButtonBaseStyle}">
            <Setter Property="BorderBrush" Value="DodgerBlue"/>
            <Setter Property="Background" Value="LightBlue"/>
        </Style>
        <Style TargetType="Button" x:Key="BrideButtonStyle"  BasedOn="{StaticResource ButtonBaseStyle}">
            <Setter Property="BorderBrush" Value="DeepPink"/>
            <Setter Property="Background" Value="LightPink"/>
        </Style>
    </Window.Resources>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="100"/>
            <RowDefinition/>
        </Grid.RowDefinitions>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <TextBlock Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="2" Style="{StaticResource DescStyle}">
            대상 축의대(신랑측 / 신부측)를 선택하세요.
        </TextBlock>

        <Button Grid.Row="1" Grid.Column="0" Content="신랑측" 
                Style="{StaticResource GroomButtonStyle}"
                Command="{Binding SelectGroomCommand}"/>
        <Button Grid.Row="1" Grid.Column="1" Content="신부측" 
                Style="{StaticResource BrideButtonStyle}"
                Command="{Binding SelectBrideCommand}"/>
    </Grid>
</Window>
